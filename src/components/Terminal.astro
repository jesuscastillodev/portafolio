---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={["terminal-window glass rounded-2xl overflow-hidden shadow-2xl shadow-black/10 dark:shadow-black/30", className]}>
  <!-- Title bar -->
  <div class="flex items-center gap-2 px-4 py-3 bg-gray-100/80 dark:bg-white/[0.04] border-b border-gray-200/50 dark:border-white/5">
    <div class="flex gap-1.5">
      <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
      <div class="w-3 h-3 rounded-full bg-amber-400/80"></div>
      <div class="w-3 h-3 rounded-full bg-emerald-400/80"></div>
    </div>
    <span class="text-[10px] font-mono font-medium text-gray-400 dark:text-gray-500 ml-2">~/jcastillo.dev</span>
  </div>

  <!-- Terminal content -->
  <div class="p-5 font-mono text-[13px] leading-relaxed space-y-2 bg-gray-50/50 dark:bg-[#0d0d14]">
    <div class="flex gap-2">
      <span class="text-emerald-500 dark:text-emerald-400 select-none">$</span>
      <span class="text-gray-700 dark:text-gray-300">whoami</span>
    </div>
    <div class="text-gray-500 dark:text-gray-400 pl-4">Jesus Castillo &mdash; Software Developer</div>

    <div class="flex gap-2 mt-1">
      <span class="text-emerald-500 dark:text-emerald-400 select-none">$</span>
      <span class="text-gray-700 dark:text-gray-300">cat skills.json</span>
    </div>
    <div class="pl-4 space-y-0.5">
      <span class="text-gray-400 dark:text-gray-500">{"{"}</span>
      <div class="pl-3">
        <span class="text-purple-500 dark:text-purple-400">"frontend"</span><span class="text-gray-400">:</span>
        <span class="text-amber-600 dark:text-amber-400"> ["React", "Tailwind", "JS"]</span><span class="text-gray-400">,</span>
      </div>
      <div class="pl-3">
        <span class="text-purple-500 dark:text-purple-400">"backend"</span><span class="text-gray-400">:</span>
        <span class="text-amber-600 dark:text-amber-400"> ["Laravel", "Node.js", "PHP"]</span><span class="text-gray-400">,</span>
      </div>
      <div class="pl-3">
        <span class="text-purple-500 dark:text-purple-400">"devops"</span><span class="text-gray-400">:</span>
        <span class="text-amber-600 dark:text-amber-400"> ["Docker", "Git", "K8s"]</span>
      </div>
      <span class="text-gray-400 dark:text-gray-500">{"}"}</span>
    </div>

    <div class="flex gap-2 mt-1">
      <span class="text-emerald-500 dark:text-emerald-400 select-none">$</span>
      <span class="text-gray-700 dark:text-gray-300">echo $STATUS</span>
    </div>
    <div class="text-emerald-500 dark:text-emerald-400 pl-4 flex items-center gap-2">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
      Ready to build amazing things
    </div>

    <div class="flex gap-2 mt-1">
      <span class="text-emerald-500 dark:text-emerald-400 select-none">$</span>
      <span class="text-gray-400 dark:text-gray-600 animate-pulse">_</span>
    </div>
  </div>
</div>
