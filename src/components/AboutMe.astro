---
import type { About } from '../types/portfolio';
import LucideIcon from './LucideIcon.astro';
import Terminal from './Terminal.astro';

interface Props {
  data?: About | null;
}

const { data } = Astro.props;

const photo = data?.photo || '/images/foto.webp';
const yearsExp = new Date().getFullYear() - 2014;
---

<section class="relative min-h-[90vh] flex items-center py-32 px-6 overflow-hidden mesh-gradient">
  <div class="absolute inset-0 dot-pattern opacity-30"></div>

  <div class="relative max-w-6xl mx-auto w-full">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-20" data-animate="fadeInUp">
      <!-- Left column: Photo + Terminal -->
      <div class="relative flex-shrink-0 flex flex-col items-center gap-8">
        <!-- Photo -->
        <div class="relative group">
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-primary/20 via-purple-500/10 to-accent/20 blur-2xl scale-110 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="relative w-48 h-48 lg:w-56 lg:h-56 rounded-3xl overflow-hidden ring-1 ring-white/20 dark:ring-white/10 shadow-2xl shadow-primary/10 transition-all duration-700 group-hover:shadow-primary/20 group-hover:scale-[1.02]">
            <img
              src={photo}
              alt="Jesus Castillo"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <button
            id="builder-badge"
            class="absolute -bottom-3 -right-3 glass rounded-2xl px-4 py-2.5 shadow-xl flex items-center gap-2.5 cursor-pointer hover:scale-105 transition-all duration-300 border-0 bg-transparent"
          >
            <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
            <span id="builder-text" class="text-xs font-semibold text-gray-700 dark:text-gray-300 tracking-wide">Disponible</span>
          </button>
        </div>

        <!-- Terminal -->
        <Terminal class="w-full max-w-sm hidden lg:block" />
      </div>

      <!-- Content -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/5 dark:bg-primary/10 border border-primary/10 dark:border-primary/20 mb-6">
          <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
          <span class="text-xs font-semibold text-primary tracking-wider uppercase">Software Developer</span>
        </div>

        <h1 class="text-5xl lg:text-7xl font-black tracking-tight leading-[1.05] mb-6">
          Hola, soy<br>
          <span class="gradient-text">Jesus Castillo</span>
        </h1>

        <p class="text-lg lg:text-xl text-gray-500 dark:text-gray-400 max-w-xl mb-10 leading-relaxed font-light">
          Creo soluciones digitales robustas y escalables. Desde APIs de alto rendimiento hasta interfaces intuitivas que generan impacto real.
        </p>

        <!-- Stats -->
        <div class="flex flex-wrap gap-10 justify-center lg:justify-start mb-10">
          <div>
            <p class="text-4xl font-black tracking-tight gradient-text">{yearsExp}+</p>
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-1">Anos</p>
          </div>
          <div>
            <p class="text-4xl font-black tracking-tight gradient-text">Full Stack</p>
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-1">Especialidad</p>
          </div>
          <div>
            <p class="text-4xl font-black tracking-tight gradient-text">3+</p>
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-1">Empresas</p>
          </div>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          <a
            href="mailto:contacto@jcastillo.dev"
            class="group/btn inline-flex items-center gap-2.5 bg-primary hover:bg-primary-dark text-white font-semibold rounded-2xl px-7 py-3.5 transition-all duration-300 hover:shadow-xl hover:shadow-primary/25 hover:-translate-y-0.5"
          >
            <LucideIcon name="Mail" size={16} class="text-white/80 transition-transform duration-300 group-hover/btn:-rotate-6" />
            Contactar
          </a>
          <a
            href="https://github.com/jesuscastillodev"
            target="_blank"
            class="group/btn inline-flex items-center gap-2.5 bg-gray-50 dark:bg-white/5 hover:bg-gray-100 dark:hover:bg-white/10 border border-gray-200 dark:border-white/10 text-gray-700 dark:text-gray-300 font-semibold rounded-2xl px-7 py-3.5 transition-all duration-300 hover:-translate-y-0.5"
          >
            <LucideIcon name="Github" size={16} class="transition-transform duration-300 group-hover/btn:scale-110" />
            GitHub
          </a>
        </div>

        <!-- Mobile terminal -->
        <div class="lg:hidden mt-12">
          <Terminal class="w-full max-w-sm mx-auto" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const badge = document.getElementById('builder-badge');
  const text = document.getElementById('builder-text');
  const dot = badge?.querySelector('div');

  if (badge && text && dot) {
    const states = [
      { text: '> compiling...', dot: 'bg-amber-400' },
      { text: '> deploying...', dot: 'bg-blue-400' },
      { text: '> tests passing', dot: 'bg-cyan-400' },
      { text: '> git push ok', dot: 'bg-purple-400' },
      { text: '> build success!', dot: 'bg-emerald-400' },
    ];

    let running = false;

    badge.addEventListener('click', async () => {
      if (running) return;
      running = true;
      badge.classList.add('font-mono');

      for (const state of states) {
        dot.className = `w-2 h-2 rounded-full animate-pulse ${state.dot}`;
        text.textContent = state.text;
        text.style.opacity = '0';
        text.style.transform = 'translateY(4px)';
        await new Promise(r => setTimeout(r, 50));
        text.style.transition = 'all 0.3s ease';
        text.style.opacity = '1';
        text.style.transform = 'translateY(0)';
        await new Promise(r => setTimeout(r, 800));
      }

      await new Promise(r => setTimeout(r, 1000));
      text.style.transition = 'opacity 0.4s ease';
      text.style.opacity = '0';
      await new Promise(r => setTimeout(r, 400));
      badge.classList.remove('font-mono');
      text.textContent = 'Disponible';
      dot.className = 'w-2 h-2 rounded-full animate-pulse bg-emerald-400';
      text.style.transition = 'opacity 0.5s ease';
      text.style.opacity = '1';
      await new Promise(r => setTimeout(r, 500));
      text.style.transition = '';
      text.style.transform = '';
      running = false;
    });
  }
</script>
