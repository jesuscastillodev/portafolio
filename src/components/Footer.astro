---
import LucideIcon from './LucideIcon.astro';
import type { Social } from '../types/portfolio';

interface Props {
  socials?: Social[] | null;
}

const { socials: apiSocials } = Astro.props;

const defaultSocials = [
  { url: 'https://github.com/jesuscastillodev', icon_slug: 'Github', label: 'GitHub' },
  { url: 'https://t.me/Jcastillo_dev', icon_slug: 'Send', label: 'Telegram' },
  { url: 'mailto:contacto@jcastillo.dev', icon_slug: 'MailPlus', label: 'Email' },
];

const socialItems = apiSocials || defaultSocials;
const year = new Date().getFullYear();
---

<footer class="relative border-t border-gray-100 dark:border-white/5 py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Social links -->
      <div class="flex items-center gap-1.5">
        {socialItems.map((social) => (
          <a
            href={social.url}
            target={social.url.startsWith('mailto') ? undefined : '_blank'}
            rel={social.url.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="w-12 h-12 rounded-xl flex items-center justify-center text-gray-400 dark:text-gray-500 hover:text-primary hover:bg-primary/5 dark:hover:bg-primary/10 transition-all duration-300"
            aria-label={social.label}
          >
            <LucideIcon name={social.icon_slug} size={18} />
          </a>
        ))}
      </div>

      <!-- Branding -->
      <div class="flex flex-col items-center md:items-end gap-1">
        <p class="text-sm font-medium text-gray-400 dark:text-gray-500">
          &copy; {year} Jcastillo.dev
        </p>
        <p class="text-xs text-gray-300 dark:text-gray-600">
          Crafted with precision
        </p>
      </div>
    </div>
  </div>
</footer>
