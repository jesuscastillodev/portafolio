---
import LucideIcon from './LucideIcon.astro';

interface Props {
  title: string;
  description: string;
  role: string;
  img: string;
  imgLight?: string;
  display?: string;
  index?: number;
}

const { title, description, role, img, imgLight, display = 'ltr', index = 0 } = Astro.props;
const isRtl = display === 'rtl';
---

<div
  class:list={[
    "glass rounded-2xl overflow-hidden transition-all duration-500 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1 flex flex-col lg:flex-row items-stretch",
    isRtl && "lg:flex-row-reverse"
  ]}
  data-animate={isRtl ? "fadeInLeft" : "fadeInRight"}
>
  <!-- Image -->
  <div class="lg:w-2/5 bg-slate-50 dark:bg-slate-800/50 flex items-center justify-center p-8">
    {imgLight ? (
      <>
        <img src={img} class="max-h-32 w-auto object-contain block dark:hidden" alt={title} loading="lazy" />
        <img src={imgLight} class="max-h-32 w-auto object-contain hidden dark:block" alt={title} loading="lazy" />
      </>
    ) : (
      <img src={img} class="max-h-32 w-auto object-contain" alt={title} loading="lazy" />
    )}
  </div>

  <!-- Content -->
  <div class="lg:w-3/5 p-8 flex flex-col justify-center">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
        <LucideIcon name="Building2" size={20} class="text-primary" />
      </div>
      <div>
        <h3 class="text-xl font-bold">{title}</h3>
        <p class="text-sm font-medium text-primary">{role}</p>
      </div>
    </div>
    <p class="text-slate-600 dark:text-slate-400 leading-relaxed">{description}</p>
  </div>
</div>
