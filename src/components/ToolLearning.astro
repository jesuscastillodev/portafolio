---
import SimpleIcon from './SimpleIcon.astro';

interface Props {
  name: string;
  iconSlug: string;
}

const { name, iconSlug } = Astro.props;
---

<div class="relative flex flex-col items-center justify-center gap-2 p-3 rounded-2xl transition-all duration-300 hover:bg-primary/[0.03] dark:hover:bg-primary/[0.06] group cursor-default">
  <SimpleIcon
    slug={iconSlug}
    size={26}
    class="text-gray-300 dark:text-gray-600 opacity-60 transition-all duration-300 group-hover:opacity-100 group-hover:scale-110"
  />
  <p class="text-[11px] font-medium text-gray-400 dark:text-gray-500">{name}</p>
  <span class="text-[9px] font-semibold text-primary/70 bg-primary/[0.06] dark:bg-primary/10 rounded-full px-2 py-0.5 tracking-wider uppercase">Aprendiendo</span>
</div>
