---
import type { Project } from '../types/portfolio';
import LucideIcon from './LucideIcon.astro';

interface Props {
  projects?: Project[] | null;
}

const defaultProjects = [
  {
    title: "Boletas de Honorarios",
    description: "Calculadora de montos líquidos y brutos para boletas de honorarios en Chile.",
    img: "/images/design/trabajo1.png",
    url: "https://boleta.jcastillo.dev/",
  },
  {
    title: "GestionaApp",
    description: "Plataforma de gestión educativa integral.",
    img: "/images/design/gestiona APP.png",
    url: "",
  }
];

const { projects: apiProjects } = Astro.props;
const projectItems = apiProjects || defaultProjects;
---

<section class="py-20 px-6 bg-slate-50/50 dark:bg-slate-900/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16" data-animate="fadeInUp">
      <p class="text-sm font-medium text-primary tracking-widest uppercase mb-3">Portfolio</p>
      <h2 class="text-3xl lg:text-4xl font-bold">Proyectos Destacados</h2>
      <p class="text-slate-500 dark:text-slate-400 mt-3 max-w-xl mx-auto">Algunos de los proyectos que he desarrollado y lanzado a producción.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate-stagger>
      {projectItems.map((project) => (
        <div class="group glass rounded-2xl overflow-hidden transition-all duration-500 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1">
          <div class="relative h-48 overflow-hidden bg-slate-100 dark:bg-slate-800">
            <img
              src={project.img}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noreferrer"
                class="absolute inset-0 bg-primary/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              >
                <div class="flex items-center gap-2 text-white font-medium">
                  <LucideIcon name="ExternalLink" size={20} class="text-white" />
                  Ver proyecto
                </div>
              </a>
            )}
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold mb-1">{project.title}</h3>
            {project.description && (
              <p class="text-sm text-slate-500 dark:text-slate-400">{project.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
