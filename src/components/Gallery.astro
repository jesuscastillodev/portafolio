---
import type { Project } from '../types/portfolio';
import LucideIcon from './LucideIcon.astro';

interface Props {
  projects?: Project[] | null;
}

const defaultProjects = [
  {
    title: "Boletas de Honorarios",
    description: "Calculadora de montos liquidos y brutos para boletas de honorarios en Chile.",
    img: "/images/design/trabajo1.png",
    url: "https://boleta.jcastillo.dev/",
  },
  {
    title: "GestionaApp",
    description: "Plataforma de gestion educativa integral.",
    img: "/images/design/gestiona APP.png",
    url: "",
  }
];

const { projects: apiProjects } = Astro.props;
const projectItems = apiProjects || defaultProjects;
---

<section id="proyectos" class="py-24 lg:py-28 px-6 relative">
  <!-- Subtle background -->
  <div class="absolute inset-0 bg-gray-50/50 dark:bg-white/[0.01]"></div>

  <div class="relative max-w-6xl mx-auto">
    <div class="text-center mb-20" data-animate="fadeInUp">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/5 dark:bg-primary/10 border border-primary/10 dark:border-primary/20 mb-5">
        <span class="text-xs font-semibold text-primary tracking-wider uppercase">Portfolio</span>
      </div>
      <h2 class="text-4xl lg:text-5xl font-black tracking-tight">Proyectos Destacados</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-4 max-w-lg mx-auto leading-relaxed">
        Algunos de los proyectos que he desarrollado y lanzado a produccion.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-animate-stagger>
      {projectItems.map((project) => (
        <div class="group glow-card glass rounded-3xl overflow-hidden transition-all duration-500 hover:-translate-y-1">
          <div class="relative h-52 overflow-hidden bg-gray-50 dark:bg-white/[0.03]">
            <img
              src={project.img}
              alt={project.title}
              class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Overlay -->
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noreferrer"
                class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/60 to-transparent flex items-end justify-start p-6 opacity-0 group-hover:opacity-100 transition-all duration-500"
              >
                <div class="flex items-center gap-2 text-white font-semibold text-sm translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                  <LucideIcon name="ExternalLink" size={16} class="text-white" />
                  Ver proyecto
                </div>
              </a>
            )}
          </div>
          <div class="p-7">
            <h3 class="text-lg font-bold tracking-tight mb-1.5">{project.title}</h3>
            {project.description && (
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{project.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
