---
import Tool from './Tool.astro';
import ToolLearning from './ToolLearning.astro';
import LucideIcon from './LucideIcon.astro';

interface ToolData {
  name: string;
  iconSlug: string;
  learning?: boolean;
}

interface Props {
  title: string;
  icon: string;
  tools: ToolData[];
}

const { title, icon, tools } = Astro.props;
---

<div
  class="glow-card glass rounded-3xl p-7 transition-all duration-500 hover:-translate-y-1"
  data-animate="fadeInUp"
>
  <div class="flex items-center gap-3 mb-7">
    <div class="w-10 h-10 rounded-2xl bg-primary/5 dark:bg-primary/10 flex items-center justify-center border border-primary/10 dark:border-primary/20">
      <LucideIcon name={icon} size={18} class="text-primary" />
    </div>
    <h3 class="text-lg font-bold tracking-tight">{title}</h3>
  </div>
  <div class="grid grid-cols-3 gap-2" data-animate-stagger>
    {tools.map((tool) =>
      tool.learning ? (
        <ToolLearning name={tool.name} iconSlug={tool.iconSlug} />
      ) : (
        <Tool name={tool.name} iconSlug={tool.iconSlug} />
      )
    )}
  </div>
</div>
