---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jesus Castillo - Software Developer",
  description = "Portfolio de Jesus Castillo, desarrollador de software con +10 anos de experiencia. Especializado en React, Laravel, Node.js y soluciones tecnologicas innovadoras."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Jesus Castillo" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Fonts: Inter for body, Space Grotesk for headings (geometric, modern, premium) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-[#0f0f1a] dark:bg-[#0a0a0f] dark:text-[#f0f0f5] transition-colors duration-700">
    <div class="relative w-full overflow-hidden min-h-screen">
      <!-- Ambient background blobs -->
      <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
        <div class="absolute -top-[40%] -left-[20%] w-[70%] h-[70%] rounded-full bg-primary/[0.03] dark:bg-primary/[0.06] blur-[120px] animate-[morphBlob_20s_ease-in-out_infinite]"></div>
        <div class="absolute -bottom-[30%] -right-[20%] w-[60%] h-[60%] rounded-full bg-accent/[0.03] dark:bg-accent/[0.05] blur-[120px] animate-[morphBlob_25s_ease-in-out_infinite_reverse]"></div>
      </div>

      <slot />
    </div>

    <script is:inline>
      (function() {
        var s = localStorage.getItem('darkMode');
        if (s === 'true' || (!s && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <script is:inline>
      (function() {
        var els;
        var o = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) { e.target.classList.add('is-visible'); o.unobserve(e.target); }
          });
        }, { threshold: 0.05, rootMargin: '50px 0px -20px 0px' });
        function init() {
          els = document.querySelectorAll('[data-animate],[data-animate-stagger]');
          els.forEach(function(el) { o.observe(el); });
          // Fallback: reveal all after 3s
          setTimeout(function() {
            els.forEach(function(el) { el.classList.add('is-visible'); });
          }, 3000);
        }
        document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
      })();
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </body>
</html>
